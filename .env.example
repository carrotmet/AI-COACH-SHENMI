# =============================================================================
# 深寻觅 AI Coach - 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改
# =============================================================================

# ===========================================
# 基础应用配置
# ===========================================
# 运行环境: development | production
APP_ENV=production

# 调试模式: true | false
DEBUG=false

# 服务器监听配置
HOST=0.0.0.0
PORT=8000

# ===========================================
# 安全配置（重要：生产环境必须修改）
# ===========================================
# JWT密钥 - 用于Token签名，请使用强随机字符串
# 生成命令: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT算法
JWT_ALGORITHM=HS256

# Access Token过期时间（分钟）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh Token过期时间（天）
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# 数据库配置
# ===========================================
# SQLite数据库路径
DATABASE_URL=sqlite:///data/ai_coach.db

# 数据库连接池大小
DATABASE_POOL_SIZE=10

# ===========================================
# AI服务配置（至少配置一个）
# ===========================================
# OpenAI API密钥
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI API基础URL（可选，用于代理或Azure）
OPENAI_BASE_URL=https://api.openai.com/v1

# 使用的LLM模型
LLM_MODEL=gpt-4o-mini

# LLM温度参数（0-1，越高越随机）
LLM_TEMPERATURE=0.7

# 最大Token数
LLM_MAX_TOKENS=2000

# 可选：Anthropic API密钥
ANTHROPIC_API_KEY=

# 可选：Azure OpenAI配置
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# ===========================================
# 对话限制配置
# ===========================================
# 免费用户每日对话次数限制
FREE_DAILY_CHAT_LIMIT=3

# 基础版用户每日对话次数限制
BASIC_DAILY_CHAT_LIMIT=20

# 专业版用户每日对话次数限制（-1表示无限）
PRO_DAILY_CHAT_LIMIT=-1

# ===========================================
# Redis缓存配置（可选）
# ===========================================
# Redis连接URL
REDIS_URL=redis://redis:6379/0

# 是否启用Redis
USE_REDIS=false

# ===========================================
# 日志配置
# ===========================================
# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=/app/logs/app.log

# 单个日志文件最大大小（字节）
LOG_MAX_BYTES=10485760

# 保留的日志文件数量
LOG_BACKUP_COUNT=5

# ===========================================
# 前端配置
# ===========================================
# Nginx服务器名称
NGINX_HOST=localhost

# ===========================================
# 支付配置（可选，用于订阅功能）
# ===========================================
# Stripe配置
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# 微信支付配置
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_APP_ID=

# ===========================================
# 通知配置（可选）
# ===========================================
# 邮件服务
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# 短信服务（阿里云）
ALIYUN_SMS_ACCESS_KEY=
ALIYUN_SMS_SECRET=
ALIYUN_SMS_SIGN_NAME=

# ===========================================
# 监控配置（可选）
# ===========================================
# Sentry DSN（错误监控）
SENTRY_DSN=

# Prometheus指标端口
METRICS_PORT=9090

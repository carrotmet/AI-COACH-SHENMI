# =====================================================
# 深寻觅 AI Coach - 环境变量配置示例
# =====================================================
# 复制此文件为 .env 并根据实际情况修改配置
# =====================================================

# =====================================================
# 应用基础配置
# =====================================================
APP_NAME=深寻觅 AI Coach
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# =====================================================
# 数据库配置
# =====================================================
# SQLite数据库URL（开发环境）
DATABASE_URL=sqlite+aiosqlite:///./ai_coach.db
# 生产环境建议使用PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_coach

# 是否打印SQL语句（调试用）
DATABASE_ECHO=false

# =====================================================
# JWT认证配置
# =====================================================
# JWT密钥（生产环境必须修改为强密码）
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# JWT算法
JWT_ALGORITHM=HS256

# Access Token过期时间（分钟）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh Token过期时间（天）
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =====================================================
# 密码安全配置
# =====================================================
# 密码最小长度
PASSWORD_MIN_LENGTH=6

# 密码最大长度
PASSWORD_MAX_LENGTH=20

# bcrypt加密轮数（数值越大越安全但越慢）
BCRYPT_ROUNDS=12

# =====================================================
# CORS配置
# =====================================================
# 允许的跨域来源（生产环境应限制为具体域名）
CORS_ORIGINS=["*"]
# 生产环境示例：CORS_ORIGINS=["https://shenxunmi.com", "https://app.shenxunmi.com"]

# 允许跨域携带凭证
CORS_ALLOW_CREDENTIALS=true

# 允许的HTTP方法
CORS_ALLOW_METHODS=["*"]

# 允许的HTTP头
CORS_ALLOW_HEADERS=["*"]

# =====================================================
# 日志配置
# =====================================================
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志格式：json/text
LOG_FORMAT=text

# 日志文件路径（可选）
# LOG_FILE=./logs/app.log

# =====================================================
# 业务配置
# =====================================================
# 默认订阅类型
DEFAULT_PLAN_TYPE=free

# 默认对话配额
DEFAULT_CONVERSATION_LIMIT=10

# 默认消息配额
DEFAULT_MESSAGE_LIMIT=100

# 默认评估配额
DEFAULT_ASSESSMENT_LIMIT=1

# 默认AI调用配额
DEFAULT_AI_CALL_LIMIT=100

# 会话超时时间（小时）
SESSION_TIMEOUT_HOURS=24

# 单对话最大消息数
MAX_CONVERSATION_LENGTH=100

# 单消息最大字符数
MAX_MESSAGE_LENGTH=4000

# =====================================================
# API配置
# =====================================================
# API版本1前缀
API_V1_PREFIX=/api/v1

# API文档标题
API_TITLE=深寻觅 AI Coach API
